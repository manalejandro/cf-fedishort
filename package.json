{
  "name": "cf-fedishort",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "db:migrate": "wrangler d1 execute cf-fedishort --remote --file=lib/db/schema.sql",
    "db:drop": "wrangler d1 execute cf-fedishort --remote --file=lib/db/drop.sql"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "@opennextjs/cloudflare": "^1.20.1",
    "nanoid": "^5.1.16",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "wrangler": "^4.110.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
